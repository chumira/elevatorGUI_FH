<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="517.0" prefWidth="753.0" xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.GuiController">
    <bottom>
        <HBox prefHeight="78.0" prefWidth="753.0" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" text="Fahrgast"/>
                <Button fx:id="timerButton" mnemonicParsing="false" onAction="#toggleTimerButton" text="Uhrzeit"/>
            </children>
        </HBox>
    </bottom>
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="59.0" prefWidth="753.0" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" onAction="#setSelectedSerialPort" text="connect"/>
                <ListView fx:id="serialPane" prefHeight="59.0" prefWidth="300.0"/>
                <Button fx:id="reloadSerial" mnemonicParsing="false" onAction="#showSerialPorts" text="reload"/>
                <Button mnemonicParsing="false" onAction="#testCommport2" text="startloop"/>
                <Button mnemonicParsing="false" onAction="#testGrid" text="testGrid"/>
            </children>
        </HBox>
    </top>
    <center>
        <ScrollPane fx:id="ePaneTest" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <content>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="200.0" prefWidth="200.0"/>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
